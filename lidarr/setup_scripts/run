#!/usr/bin/env bash
# -------------------------------------------------------------------------------------------------------------
# Arrbit - run module
# Version: v2.3-gs2.7.1
# Purpose: Orchestrator – runs setup first, then executes all Arrbit service modules (silent except ERROR).
# -------------------------------------------------------------------------------------------------------------

set -euo pipefail

ARRBIT_ROOT="/config/arrbit"
HELPERS_DIR="$ARRBIT_ROOT/helpers"
LOGO_SCRIPT_LOCAL="$ARRBIT_ROOT/modules/data/arrbit_logo.bash"
REMOTE_SETUP_URL="https://raw.githubusercontent.com/prvctech/Arrbit/main/lidarr/setup_scripts/setup.bash"

DEPENDENCIES_SCRIPT="$ARRBIT_ROOT/setup/dependencies.bash"
PLUGINS_SCRIPT_LOCAL="$ARRBIT_ROOT/services/plugins.bash"
AUTOCONFIG_SCRIPT_LOCAL="$ARRBIT_ROOT/services/autoconfig.bash"

sleep 8

# --- 1. Run remote setup first (absolutely no output unless ERROR) ---
if ! curl --fail --silent --show-error "$REMOTE_SETUP_URL" | bash; then
  echo "[Arrbit] ERROR: Failed to run remote setup.bash"
  exit 1
fi

# --- 2. Verify helpers exist after setup, or fatal error (silent otherwise) ---
if [[ ! -f "$HELPERS_DIR/logging_utils.bash" || ! -f "$HELPERS_DIR/helpers.bash" ]]; then
  echo "[Arrbit] ERROR: Arrbit helpers missing after setup. Cannot continue."
  exit 1
fi

# --- 3. Source helpers, set up log file, show logo if present ---
source "$HELPERS_DIR/logging_utils.bash"
source "$HELPERS_DIR/helpers.bash"
arrbitPurgeOldLogs

SCRIPT_NAME="run"
SCRIPT_VERSION="v2.3-gs2.7.1"
LOG_FILE="/config/logs/arrbit-${SCRIPT_NAME}-$(date '+%Y_%m_%d-%H_%M').log"
touch "$LOG_FILE" && chmod 777 "$LOG_FILE"

if [[ -f "$LOGO_SCRIPT_LOCAL" ]]; then
  source "$LOGO_SCRIPT_LOCAL"
  arrbit_logo
fi
echo

# --- 4. Run dependencies script FIRST (before trying to read YAML) ---
if [[ -x "$DEPENDENCIES_SCRIPT" ]]; then
  log_info "Running dependencies script..."
  bash "$DEPENDENCIES_SCRIPT"
else
  log_error "Dependencies script missing or not executable: $DEPENDENCIES_SCRIPT"
  cat <<EOF | arrbitLogClean >> "$LOG_FILE"
[Arrbit] ERROR Dependencies script not found/executable
[WHY]: $DEPENDENCIES_SCRIPT missing or not executable after setup.
[FIX]: Check permissions and path. See setup logs for detail.
EOF
  exit 1
fi

# --- 5. Source configuration utilities (after dependencies are installed) ---
CONFIG_UTILS="$HELPERS_DIR/config_utils.bash"
CONFIG_VALIDATOR="$HELPERS_DIR/config_validator.bash"

if [[ ! -f "$CONFIG_UTILS" ]]; then
  log_error "Configuration utilities missing: $CONFIG_UTILS (see log at /config/logs)"
  cat <<EOF | arrbitLogClean >> "$LOG_FILE"
[Arrbit] ERROR Configuration utilities missing
[WHY]: $CONFIG_UTILS not found after setup
[FIX]: Check that the repository includes the config_utils.bash file
EOF
  exit 1
fi

source "$CONFIG_UTILS"

if [[ -f "$CONFIG_VALIDATOR" ]]; then
  source "$CONFIG_VALIDATOR"
  log_info "Configuration validation enabled"
fi

# --- 6. Check YAML configuration exists ---
if ! config_exists; then
  log_error "Configuration file missing: arrbit-config.yaml (see log at /config/logs)"
  cat <<EOF | arrbitLogClean >> "$LOG_FILE"
[Arrbit] ERROR Configuration file missing
[WHY]: arrbit-config.yaml not found in /config/arrbit/config/
[FIX]: Create a configuration file based on the example in the repository
EOF
  exit 1
fi

# --- 7. Check enable_arrbit flag ---
ENABLE_ARRBIT=$(get_yaml_value "enable_arrbit")

# Validate if validator is available
if type validate_boolean >/dev/null 2>&1; then
  if ! validate_boolean "enable_arrbit" "$ENABLE_ARRBIT"; then
    ENABLE_ARRBIT="false"
  fi
fi

if [[ "${ENABLE_ARRBIT,,}" != "true" ]]; then
  log_warning "Arrbit services are OFF. Set enable_arrbit to 'true' in arrbit-config.yaml to enable automation. (see log at /config/logs)"
  cat <<EOF | arrbitLogClean >> "$LOG_FILE"
[Arrbit] WARNING Arrbit services are OFF.
[WHY]: enable_arrbit is set to false in arrbit-config.yaml.
[FIX]: Edit /config/arrbit/config/arrbit-config.yaml and set enable_arrbit: true to enable Arrbit automation.
EOF
  sleep infinity
fi

# --- 8. Run plugins script ---
if [[ -x "$PLUGINS_SCRIPT_LOCAL" ]]; then
  bash "$PLUGINS_SCRIPT_LOCAL"
fi

# --- 9. Run autoconfig script ---
if [[ -x "$AUTOCONFIG_SCRIPT_LOCAL" ]]; then
  bash "$AUTOCONFIG_SCRIPT_LOCAL"
fi

log_info "All requested services executed. Sleeping indefinitely."
sleep infinity
