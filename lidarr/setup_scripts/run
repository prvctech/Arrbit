#!/usr/bin/env bash
# ------------------------------------------------------------
# Arrbit [run]
# Version: 2.5
# Purpose: Main entrypoint for Arrbit; auto-updates, installs configs, runs dependencies, shows logo, and launches main Arrbit scripts.
# ------------------------------------------------------------

set +e

GITHUB_REPO="https://github.com/prvctech/Arrbit"
GITHUB_BRANCH="main"
SERVICE_DIR="/etc/services.d/arrbit"
CONFIG_DIR="/config/arrbit"
LOG_DIR="/config/logs"
TMP_DIR="/tmp/arrbit_update_$$"

ARRBIT_TAG="\033[1;36m[Arrbit]\033[0m"
rawScriptName="run"
scriptVersion="v2.5"

logfileSetup() {
  timestamp=$(date +"%Y_%m_%d-%H_%M")
  logFileName="arrbit-${rawScriptName}-${timestamp}.log"
  logFilePath="${LOG_DIR}/${logFileName}"
  mkdir -p "${LOG_DIR}"
  find "${LOG_DIR}" -type f -iname "arrbit-${rawScriptName}-*.log" -mtime +2 -delete
  touch "$logFilePath"
  chmod 666 "$logFilePath"
}

log() {
  echo -e "$1"
  logRaw "$1"
}

logRaw() {
  local stripped
  stripped=$(echo -e "$1" \
    | sed -E 's/\x1B\[[0-9;]*[a-zA-Z]//g' \
    | sed -E 's/\033\[[0-9;]*m//g' \
    | sed -E 's/[🔵🟢⚠️📥📄⏩🚀✅❌🔧🔴🟪🟦🟩🟥📁📦]//g' \
    | sed -E 's/\\n/\n/g' \
    | sed -E 's/^[[:space:]]+\[Arrbit\]/[Arrbit]/')
  echo "$stripped" >> "$logFilePath"
}

logfileSetup

sleep 8  # Delay Arrbit logs until after container native logs

# Print Arrbit logo header FIRST, before any log or output
if [ -f "$SERVICE_DIR/modules/data/arrbit_logo.bash" ]; then
    source "$SERVICE_DIR/modules/data/arrbit_logo.bash"
    arrbit_logo
else
    # Fallback: blank lines the same width as logo for perfect alignment
    echo -e "                                    "
    echo -e "                                    "
    echo -e "                                    "
    echo -e "                                    "
fi

# Only the service start line is plain and has NO highlight/tag!
echo "Starting arrbit services..."

# Now, all logs with ARRBIT_TAG
log "📥  $ARRBIT_TAG Syncing latest scripts/modules from GitHub..."
mkdir -p "$SERVICE_DIR" "$CONFIG_DIR" "$LOG_DIR" "$TMP_DIR"
chmod -R 777 "$SERVICE_DIR" "$CONFIG_DIR" "$LOG_DIR"

curl -sfL "$GITHUB_REPO/archive/refs/heads/$GITHUB_BRANCH.zip" -o "$TMP_DIR/arrbit.zip"
unzip -q "$TMP_DIR/arrbit.zip" -d "$TMP_DIR"
cp -rf "$TMP_DIR/Arrbit-main/lidarr/process_scripts/"* "$SERVICE_DIR/"
chmod -R 777 "$SERVICE_DIR"

for cfg in arrbit-config.conf beets-config.yaml; do
  if [ ! -f "$CONFIG_DIR/$cfg" ]; then
    cp "$TMP_DIR/Arrbit-main/lidarr/config/$cfg" "$CONFIG_DIR/$cfg"
    chmod 777 "$CONFIG_DIR/$cfg"
    log "✅   $ARRBIT_TAG $cfg saved to config directory."
  else
    log "⏭️   $ARRBIT_TAG $cfg exists; skipping download."
  fi
done

rm -rf "$TMP_DIR"

log "🟢  $ARRBIT_TAG Scripts/modules updated and configs checked."

chmod -R 777 "$LOG_DIR" "$CONFIG_DIR" || true

log "🔵  $ARRBIT_TAG Running dependencies remotely from GitHub..."
curl -sfL "$GITHUB_REPO/raw/$GITHUB_BRANCH/lidarr/setup_scripts/dependencies.bash" | bash | tee -a "$logFilePath"

ENABLE_AUTOCONFIG="true"
ENABLE_COMMUNITY_PLUGINS="false"
if [ -f "$CONFIG_DIR/arrbit-config.conf" ]; then
    ENABLE_AUTOCONFIG=$(grep -E '^ENABLE_AUTOCONFIG=' "$CONFIG_DIR/arrbit-config.conf" | cut -d'=' -f2 | tr -d '\r')
    ENABLE_COMMUNITY_PLUGINS=$(grep -E '^ENABLE_COMMUNITY_PLUGINS=' "$CONFIG_DIR/arrbit-config.conf" | cut -d'=' -f2 | tr -d '\r')
fi

ARRBIT_SERVICES=()
if [[ "${ENABLE_AUTOCONFIG,,}" == "true" ]]; then
    ARRBIT_SERVICES+=("autoconfig.bash")
fi
if [[ "${ENABLE_COMMUNITY_PLUGINS,,}" == "true" ]]; then
    ARRBIT_SERVICES+=("plugins.bash")
fi

for script in "${ARRBIT_SERVICES[@]}"; do
    if [ -x "$SERVICE_DIR/$script" ]; then
        log "⏩  $ARRBIT_TAG Running $script..."
        if ! bash "$SERVICE_DIR/$script" | tee -a "$logFilePath"; then
            log "⚠️   $ARRBIT_TAG $script failed (non-zero exit, but service will continue)"
        fi
    else
        log "⚠️   $ARRBIT_TAG $script not found or not executable, skipping."
    fi
done

log "📄  $ARRBIT_TAG Log saved to $logFilePath"
log "✅  $ARRBIT_TAG Done with run!"
sleep infinity
