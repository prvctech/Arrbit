#!/usr/bin/env bash
# ------------------------------------------------------------
# Arrbit [run]
# Version: 1.8
# Purpose: Main entrypoint for Arrbit; auto-updates, installs configs, runs dependencies, and launches main Arrbit scripts.
# ------------------------------------------------------------

set +e  # Do not exit on error; allow logs to complete and sleep

GITHUB_REPO="https://github.com/prvctech/Arrbit"
GITHUB_BRANCH="main"
SERVICE_DIR="/etc/services.d/arrbit"
CONFIG_DIR="/config/arrbit"
LOG_DIR="/config/logs"
TMP_DIR="/tmp/arrbit_update_$$"
RAW_LOG="$LOG_DIR/arrbit-service-$(date +%Y%m%d-%H%M%S).log"
ARRBIT_TAG="\033[1;36m[Arrbit]\033[0m"

log() { echo -e "$1" | tee -a "$RAW_LOG"; }

# Log Rotation: purge logs after 2 days
find "$LOG_DIR" -type f -name "arrbit-*.log" -mtime +2 -delete 2>/dev/null || true

# Create required folders with 777 perms
mkdir -p "$SERVICE_DIR" "$CONFIG_DIR" "$LOG_DIR" "$TMP_DIR"
chmod -R 777 "$SERVICE_DIR" "$CONFIG_DIR" "$LOG_DIR"

sleep 8  # Delay Arrbit logging to appear after container native logs

log "🚀  $ARRBIT_TAG Arrbit service starting..."

# 1. Auto-update scripts/modules from GitHub (Golden Standard)
log "📥  $ARRBIT_TAG Syncing latest scripts/modules from GitHub..."
curl -sfL "$GITHUB_REPO/archive/refs/heads/$GITHUB_BRANCH.zip" -o "$TMP_DIR/arrbit.zip"
unzip -q "$TMP_DIR/arrbit.zip" -d "$TMP_DIR"

cp -rf "$TMP_DIR/Arrbit-main/lidarr/process_scripts/"* "$SERVICE_DIR/"
chmod -R 777 "$SERVICE_DIR"

# 2. Copy config files if missing (never overwrite existing config)
for cfg in arrbit-config.conf beets-config.yaml; do
  if [ ! -f "$CONFIG_DIR/$cfg" ]; then
    cp "$TMP_DIR/Arrbit-main/lidarr/config/$cfg" "$CONFIG_DIR/$cfg"
    chmod 777 "$CONFIG_DIR/$cfg"
    log "    • ✅ $cfg saved to config directory."
  else
    log "    • ⏭️  $cfg exists; skipping download."
  fi
done

rm -rf "$TMP_DIR"

log "🟢  $ARRBIT_TAG Scripts/modules updated and configs checked."

chmod -R 777 "$LOG_DIR" "$CONFIG_DIR" || true

# 3. Run dependencies setup (always fetch latest remotely)
log "🔵  $ARRBIT_TAG Running dependencies remotely from GitHub..."
curl -sfL "$GITHUB_REPO/raw/$GITHUB_BRANCH/lidarr/setup_scripts/dependencies.bash" | bash | tee -a "$RAW_LOG"

# 4. Parse ENABLE_AUTOCONFIG flag from arrbit-config.conf
ENABLE_AUTOCONFIG=1 # default to enabled
if [ -f "$CONFIG_DIR/arrbit-config.conf" ]; then
    ENABLE_AUTOCONFIG=$(grep -E '^ENABLE_AUTOCONFIG=' "$CONFIG_DIR/arrbit-config.conf" | cut -d'=' -f2 | tr -d '\r')
fi

ARRBIT_SERVICES=()
if [ "$ENABLE_AUTOCONFIG" = "1" ] || [[ "${ENABLE_AUTOCONFIG,,}" == "true" ]]; then
    ARRBIT_SERVICES+=("autoconfig.bash")
fi
ARRBIT_SERVICES+=("plugins_add.bash")

# 5. Run main Arrbit service scripts, one after the other (defensive, won't exit service on error)
for script in "${ARRBIT_SERVICES[@]}"; do
    if [ -x "$SERVICE_DIR/$script" ]; then
        log "⏩  $ARRBIT_TAG Running $script..."
        if ! bash "$SERVICE_DIR/$script" | tee -a "$RAW_LOG"; then
            log "⚠️   $ARRBIT_TAG $script failed (non-zero exit, but service will continue)"
        fi
    else
        log "⚠️   $ARRBIT_TAG $script not found or not executable, skipping."
    fi
done

log "✅  $ARRBIT_TAG Arrbit service complete!"
sleep infinity
