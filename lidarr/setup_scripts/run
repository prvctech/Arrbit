#!/usr/bin/env bash
# -------------------------------------------------------------------------------------------------------------
# Arrbit - run
# Version : v1.0
# Purpose : Orchestrates plugins/autoconfig by fetching remote scripts from GitHub.
# -------------------------------------------------------------------------------------------------------------

set -euo pipefail

# ---------------- paths ----------------
CONFIG_FILE="/config/arrbit/arrbit-config.conf"
GITHUB_RAW="https://raw.githubusercontent.com/prvctech/Arrbit/refs/heads/main/lidarr/process_scripts/services"

# ---------------- checks ----------------
[[ ! -f "$CONFIG_FILE" ]] && sleep infinity && exit 0

get_flag() {
  awk -F '=' -v k="$1" '$1 ~ k {gsub(/[[:space:]]/, "", $2); print tolower($2)}' "$CONFIG_FILE"
}

# ---------------- logic ----------------
if [[ "$(get_flag ENABLE_ARRBIT)" != "true" ]]; then
  sleep infinity
  exit 0
fi

if [[ "$(get_flag ENABLE_PLUGINS)" == "true" ]]; then
  bash <(curl -fsSL "$GITHUB_RAW/plugins.bash")
fi

if [[ "$(get_flag ENABLE_AUTOCONFIG)" == "true" ]]; then
  curl -fsSL "$GITHUB_RAW/autoconfig.bash" | bash >/dev/null 2>&1
fi

sleep infinity
exit 0
