#!/usr/bin/env bash
# -------------------------------------------------------------------------------------------------------------
# Arrbit - run module
# Version : v1.7-gs2.6
# Purpose : Orchestrator – shows Arrbit logo, runs remote setup.bash, installs dependencies,
#           then launches local services (plugins, autoconfig) per config flags.
# -------------------------------------------------------------------------------------------------------------

set -euo pipefail

sleep 8

ARRBIT_ROOT="/config/arrbit"
CONFIG_FILE_PRIMARY="$ARRBIT_ROOT/config/arrbit-config.conf"
CONFIG_FILE_LEGACY="$ARRBIT_ROOT/arrbit-config.conf"
LOG_DIR="/config/logs"
HELPERS_DIR="$ARRBIT_ROOT/helpers"

DEPENDENCIES_SCRIPT="$ARRBIT_ROOT/setup/dependencies.bash"
REMOTE_SETUP_URL="https://raw.githubusercontent.com/prvctech/Arrbit/main/lidarr/setup_scripts/setup.bash"
PLUGINS_SCRIPT_LOCAL="$ARRBIT_ROOT/services/plugins.bash"
AUTOCONFIG_SCRIPT_LOCAL="$ARRBIT_ROOT/services/autoconfig.bash"
LOGO_SCRIPT_LOCAL="$ARRBIT_ROOT/modules/data/arrbit_logo.bash"

# --- Banner (color before helpers exist) ---
CYAN='\033[96m'
YELLOW='\033[93m'
NC='\033[0m'
echo -e "${CYAN}[Arrbit]${NC} ${YELLOW}run module${NC} v1.7-gs2.6 starting …"

# Show logo if present
if [[ -f "$LOGO_SCRIPT_LOCAL" ]]; then
  bash "$LOGO_SCRIPT_LOCAL"
fi

# --- 1. Fetch & execute remote setup (brings helpers into existence) ---
echo -e "${CYAN}[Arrbit]${NC} Fetching and executing remote setup.bash ..."
if ! curl --fail --silent --show-error "$REMOTE_SETUP_URL" | bash; then
  echo -e "${CYAN}[Arrbit]${NC} ERROR: remote setup.bash failed."
  exit 1
fi
echo -e "${CYAN}[Arrbit]${NC} Remote setup complete."

# --- 2. Now helpers exist! Switch to full Golden Standard logging ---
if [[ -f "$HELPERS_DIR/logging_utils.bash" && -f "$HELPERS_DIR/helpers.bash" ]]; then
  source "$HELPERS_DIR/logging_utils.bash"
  source "$HELPERS_DIR/helpers.bash"
  arrbitPurgeOldLogs 2
  SCRIPT_NAME="run"
  SCRIPT_VERSION="v1.7-gs2.6"
  LOG_FILE="$LOG_DIR/arrbit-${SCRIPT_NAME}-$(date '+%Y_%m_%d-%H_%M').log"
  touch "$LOG_FILE" && chmod 777 "$LOG_FILE"
else
  echo -e "${CYAN}[Arrbit]${NC} ERROR: Arrbit helpers missing after setup. Cannot continue."
  exit 1
fi

# --- 3. Install prerequisites ---
log_info "Running dependencies setup ..."
if [[ -x "$DEPENDENCIES_SCRIPT" ]]; then
  bash "$DEPENDENCIES_SCRIPT"
  log_info "Dependencies completed."
else
  log_error "dependencies script not found/executable at $DEPENDENCIES_SCRIPT"
  exit 1
fi

# --- 4. Locate config file ---
if [[ -f "$CONFIG_FILE_PRIMARY" ]]; then
  CONFIG_FILE="$CONFIG_FILE_PRIMARY"
elif [[ -f "$CONFIG_FILE_LEGACY" ]]; then
  CONFIG_FILE="$CONFIG_FILE_LEGACY"
else
  log_error "arrbit-config.conf not found."
  exit 1
fi

# --- 4b. Check ENABLE_CONFIG flag ---
ENABLE_CONFIG=$(getFlag ENABLE_CONFIG)
if [[ "${ENABLE_CONFIG,,}" != "true" ]]; then
  log_warning "Arrbit services are OFF. Update ENABLE_CONFIG to 'true' in arrbit-config.conf to enable automation."
  log_info "Log saved to $LOG_FILE"
  exit 0
fi

# --- 5. Read config flags using real helpers.getFlag ---
log_info "Reading config flags from $CONFIG_FILE ..."

# --- 6. Conditional service launches ---
if [[ "$(getFlag ENABLE_PLUGINS)" == "true" ]]; then
  if [[ -x "$PLUGINS_SCRIPT_LOCAL" ]]; then
    log_info "Launching plugins.bash ..."
    bash "$PLUGINS_SCRIPT_LOCAL"
    log_info "plugins.bash finished."
  else
    log_warning "plugins.bash not found at $PLUGINS_SCRIPT_LOCAL"
  fi
fi

if [[ "$(getFlag ENABLE_AUTOCONFIG)" == "true" ]]; then
  if [[ -x "$AUTOCONFIG_SCRIPT_LOCAL" ]]; then
    log_info "Launching autoconfig.bash ..."
    bash "$AUTOCONFIG_SCRIPT_LOCAL"
    log_info "autoconfig.bash finished."
  else
    log_warning "autoconfig.bash not found at $AUTOCONFIG_SCRIPT_LOCAL"
  fi
fi

# --- End ---
log_info "All requested services executed. Sleeping indefinitely."
log_info "Log saved to $LOG_FILE"
sleep infinity
